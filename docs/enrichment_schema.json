      }
    },
    "assumed_pain_points": {
      "type": "array",
      "minItems": 2,
      "maxItems": 5,
      "items": {
        "type": "string"
      }
    },
    "message_angle": {
      "type": "string"
    },
    "suggested_next_action": {
      "type": "string",
      "enum": ["generate_message", "review", "skip"]
    }
  },
  "required": [
    "business_model_guess",
    "is_icp_fit",
    "fit_score",
    "priority_score",
    "fit_reason",
    "disqualify_reason",
    "observations",
    "assumed_pain_points",
    "message_angle",
    "suggested_next_action"
